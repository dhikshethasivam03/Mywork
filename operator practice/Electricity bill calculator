import java.util.Scanner;

class Main {
    public static void main(String[] args) {

        int units = new Scanner(System.in).nextInt();

        double bill;

        if(units <= 100)
            bill = units * 5;
        else if(units <= 200)
            bill = units * 7;
        else
            bill = units * 10;

        System.out.println(bill);
    }
}