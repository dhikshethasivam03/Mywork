import java.util.Scanner;

class Main {
    public static void main(String[] args) {

        int num = new Scanner(System.in).nextInt();

        int d1 = num / 100;
        int d2 = (num / 10) % 10;
        int d3 = num % 10;

        int reverse = d3 * 100 + d2 * 10 + d1;

        System.out.println(reverse);
    }
}