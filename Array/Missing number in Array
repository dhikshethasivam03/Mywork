class Main{
    public static void main(String[] args){
        int[] a = {1,2,4,5};
        int n = a.length + 1;
        int sum1 = 0;
        int sum2 = 0;
        for(int i= 0; i < a.length; i++){
            sum1 = sum1+a[i];
        }
        for(int i = 0; i <= n; i++){
            sum2 = sum2+i;
        }
        int missing = sum2 -sum1;
        System.out.print("Missing Number; " + missing);
    }
}