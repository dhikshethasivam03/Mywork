class Main{
    public static void main(String[] args){
        int[] ar= {2,2,3,4,4,5,5,6,8};
        int rd = 0;
        for(int i = 1; i < ar.length; i++){
            if(ar[rd] != ar[i]){
                rd++;
                ar[rd] = ar[i];
            }
        }
        System.out.print("Array after removing duplicates");
        for(int i = 0; i <= rd; i++){
            System.out.print(ar[i] + " ");
        }
    }
}