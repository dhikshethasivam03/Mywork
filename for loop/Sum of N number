import java.util.Scanner;
class Main{
    public static void main(String[] args){
        Scanner sc =  new Scanner(System.in);
        System.out.print("Enter the valid number : ");
        int input = sc.nextInt();
        int add = 0;
        for(int i = 0; i <= input; i++){
            add = add + i;
        }
        
        System.out.println(add);    
    
        
    
    }
}