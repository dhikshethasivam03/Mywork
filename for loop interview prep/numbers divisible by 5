import java.util.Scanner;
class Main{
    public static void main(String[] args){
        Scanner sc= new Scanner(System.in);
        System.out.print("Enter ur number : ");
        int n = sc.nextInt();
        int num = 0;
        for(int i = 1; i <= n; i++){
            if(i % 5 == 0)
            num++;
        }
        System.out.println(num);
    }
     
     
} 